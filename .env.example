# ========================================
# RURAL INDIA AI - ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env and fill in the actual values
# NEVER commit .env to git - it contains secrets

# ========== SERVER CONFIGURATION ==========
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production
DEBUG=False

# ========== SECURITY ==========
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY=your-api-key-here

# ========== MQTT CONFIGURATION ==========
MQTT_BROKER=mqtt.example.com
MQTT_PORT=1883
MQTT_CLIENT_ID=edge_node_001
MQTT_USERNAME=optional_username
MQTT_PASSWORD=optional_password
MQTT_TLS_ENABLED=False

# ========== DATABASE CONFIGURATION ==========
QUEUE_DB_PATH=./data/queue.db
VECTOR_DB_PATH=./data/vector_db.json
METRICS_DB_PATH=./data/metrics/metrics.json

# ========== AI MODELS ==========
WHISPER_MODEL_SIZE=tiny
ENABLE_VOICE_INPUT=True
DEFAULT_LANGUAGE=en

# ========== OBSERVABILITY ==========
LOG_LEVEL=INFO
LOG_FILE=logs/api_server.log
ENABLE_METRICS=True
METRICS_PORT=9090

# ========== CORS CONFIGURATION ==========
# For production, specify actual domains
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ========== BETA LAUNCH SETTINGS ==========
BETA_MODE=True
REQUIRE_CONSENT=True
TELEMETRY_ENABLED=True

# ========== RENDER.COM DEPLOYMENT ==========
# These are auto-set by Render, but shown for reference
# DATABASE_URL=
# REDIS_URL=
